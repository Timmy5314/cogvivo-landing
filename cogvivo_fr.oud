    <li><a href="/disclaimer">// Avertissement</a></li>
    <li><a href="mailto:info@cogvivo.com">// Contact</a></li>
  </ul>
  <div style="margin-top:32px;padding-top:24px;border-top:1px solid rgba(255,255,255,0.04);text-align:center;">
    <p style="font-size:9px;letter-spacing:.12em;color:var(--t4);line-height:2.2;text-transform:uppercase;max-width:900px;margin:0 auto;">
      Cogvivo — Immatriculé à la Chambre de commerce des Pays-Bas &nbsp;·&nbsp; Amsterdam, Pays-Bas<br>
      Ce produit est un complément alimentaire et non un médicament &nbsp;·&nbsp; Ne remplace pas une alimentation variée et équilibrée ni un mode de vie sain<br>
      Ne pas dépasser la dose journalière recommandée &nbsp;·&nbsp; Tenir hors de portée des enfants<br>
      Consulter un médecin en cas de grossesse, d'allaitement ou de prise de médicaments &nbsp;·&nbsp; Végan · sans gluten · sans soja · Ne convient pas aux moins de 18 ans<br>
      Seules des allégations de santé EFSA reconnues sont utilisées, conformément au règlement (CE) n° 1924/2006. Ce produit ne diagnostique, ne traite ni ne guérit aucune maladie. Les mécanismes mentionnés constituent un contexte scientifique, non une allégation de santé.
    </p>
  </div>
</footer>

<script>
/* CURSOR */
const CD=document.getElementById('CUR'),CR=document.getElementById('CURR');
let mx=-9999,my=-9999,rx=0,ry=0;
addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;CD.style.left=mx+'px';CD.style.top=my+'px';});
(function a(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;CR.style.left=rx+'px';CR.style.top=ry+'px';requestAnimationFrame(a);})();
document.querySelectorAll('a,.go-card,.tc,.ic,.price-card,.ts,.ritual-step,.lex-item').forEach(el=>{
  el.addEventListener('mouseenter',()=>document.body.classList.add('hl'));
  el.addEventListener('mouseleave',()=>document.body.classList.remove('hl'));
});

/* NAV */
addEventListener('scroll',()=>document.getElementById('NAV').classList.toggle('solid',scrollY>60));

/* SCROLL REVEAL */
const ro=new IntersectionObserver(e=>{
  e.forEach(x=>{if(x.isIntersecting){x.target.classList.add('in');ro.unobserve(x.target);}});
},{threshold:.06,rootMargin:'0px 0px -10px 0px'});
document.querySelectorAll('.rv').forEach(el=>ro.observe(el));

/* EVIDENCE BARS */
const bo=new IntersectionObserver(e=>{
  e.forEach(x=>{if(x.isIntersecting){x.target.style.width=x.target.dataset.w+'%';bo.unobserve(x.target);}});
},{threshold:.1});
document.querySelectorAll('.ev-fill').forEach(b=>bo.observe(b));

/* SCARCITY BAR */
const sb=document.getElementById('SCBAR');
if(sb){const so=new IntersectionObserver(e=>{
  e.forEach(x=>{if(x.isIntersecting){setTimeout(()=>sb.style.width=sb.dataset.w+'%',400);so.unobserve(x.target);}});
},{threshold:.2});so.observe(sb);}

/* SCORE BARS */
const scoreObs=new IntersectionObserver(e=>{
  e.forEach(x=>{if(x.isIntersecting){
    x.target.querySelectorAll('.ct-score-bar').forEach(b=>b.style.width=b.dataset.w+'%');
    scoreObs.unobserve(x.target);
  }});
},{threshold:.2});
document.querySelectorAll('.ct-scores').forEach(el=>scoreObs.observe(el));

/* OPT-IN FORM */
const optinBtn=document.querySelector('.optin-btn');
const optinInput=document.querySelector('.optin-input');
if(optinBtn&&optinInput){
  optinBtn.addEventListener('click',()=>{
    const val=optinInput.value.trim();
    if(!val||!val.includes('@')){
      optinInput.style.borderColor='rgba(200,80,80,.5)';
      setTimeout(()=>optinInput.style.borderColor='',1500);
      return;
    }
    optinBtn.textContent='✓ Je staat op de lijst';
    optinBtn.style.background='var(--goldhi)';
    optinInput.value='';
    optinInput.placeholder='Je hoort als eerste van ons';
  });
}

/* FAQ ACCORDION */
document.querySelectorAll('.faq-q').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const item=btn.parentElement;
    const open=item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));
    if(!open) item.classList.add('open');
  });
});

/* SCROLL PROGRESS */
const _prog=document.getElementById('progress');
addEventListener('scroll',()=>{
  const st=document.documentElement.scrollTop||document.body.scrollTop;
  const sh=(document.documentElement.scrollHeight||document.body.scrollHeight)-document.documentElement.clientHeight;
  _prog.style.width=(sh>0?(st/sh)*100:0)+'%';
},{passive:true});

/* COUNT-UP on numeric stats (35, 14, 100%) — leaves AM·PM / EU untouched */
function countUp(el){
  const raw=el.textContent.trim();
  const m=raw.match(/^(\d+)(%?)$/);
  if(!m) return;
  const target=parseInt(m[1],10), suffix=m[2];
  const dur=1100, t0=performance.now();
  function step(now){
    const p=Math.min((now-t0)/dur,1);
    const eased=1-Math.pow(1-p,3);
    el.textContent=Math.round(eased*target)+suffix;
    if(p<1) requestAnimationFrame(step);
    else el.textContent=target+suffix;
  }
  requestAnimationFrame(step);
}
const _numObs=new IntersectionObserver(es=>{
  es.forEach(x=>{if(x.isIntersecting){countUp(x.target);_numObs.unobserve(x.target);}});
},{threshold:.4});
document.querySelectorAll('.ts-val').forEach(el=>{ if(/^\d+%?$/.test(el.textContent.trim())) _numObs.observe(el); });

/* MAGNETIC BUTTONS (desktop only) */
if(window.matchMedia('(hover:hover) and (pointer:fine)').matches){
  document.querySelectorAll('.btn-main,.nav-cta,.pc-cta').forEach(btn=>{
    btn.addEventListener('mousemove',e=>{
      const r=btn.getBoundingClientRect();
      const mx=e.clientX-(r.left+r.width/2);
      const my=e.clientY-(r.top+r.height/2);
      btn.style.transform=`translate(${mx*0.18}px, ${my*0.28}px)`;
    });
    btn.addEventListener('mouseleave',()=>{btn.style.transform='translate(0,0)';});
  });
}

/* LANGUAGE AUTO-DETECT (first visit only; respects manual choice) */
(function(){
  try{
    var stored=localStorage.getItem('cogvivo_lang');
    var here=(document.documentElement.lang||'nl');
    if(stored){ /* user already chose: honour it if different */ 
      if(stored!==here){ var map={nl:'index.html',en:'cogvivo_en.html',de:'cogvivo_de.html',fr:'cogvivo_fr.html'};
        if(map[stored]&&!sessionStorage.getItem('cogvivo_redirected')){sessionStorage.setItem('cogvivo_redirected','1');location.replace(map[stored]);}
      }
      return;
    }
    if(sessionStorage.getItem('cogvivo_redirected'))return;
    var nav=(navigator.language||'en').slice(0,2).toLowerCase();
    var supported={en:'cogvivo_en.html',de:'cogvivo_de.html',fr:'cogvivo_fr.html',nl:'index.html'};
    if(supported[nav]&&nav!==here){sessionStorage.setItem('cogvivo_redirected','1');location.replace(supported[nav]);}
  }catch(e){}
})();
/* store choice when a language link is clicked */
document.querySelectorAll('.langsel a').forEach(function(a){
  a.addEventListener('click',function(){
    var code=a.textContent.trim().toLowerCase();
    try{localStorage.setItem('cogvivo_lang',code);}catch(e){}
  });
});
</script>
</body>
</html>
