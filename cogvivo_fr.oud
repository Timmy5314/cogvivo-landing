<!-- FOOTER -->
<footer>
  <div class="foot-logo">COGVIVO<em>.</em></div>
  <p class="foot-copy">© 2026 Cogvivo — Amsterdam, Pays-Bas</p>
  <ul class="foot-links">
    <li><a href="#ingredients">// Formule</a></li>
    <li><a href="#protocol">// Protocole</a></li>
    <li><a href="#why">// Science</a></li>
    <li><a href="/voorwaarden">// CGV</a></li>
